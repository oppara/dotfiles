#!/usr/bin/env bash

set -euo pipefail

# [思考を減らしコードに集中するための tmux, Neovim 設定](https://zenn.dev/layerx/articles/8c29b0367238b8)
# https://github.com/izumin5210/dotfiles/blob/aa17b272068491d24e7e52bd9fb58903c6947e4f/config/.bin/tm

changeSession() {
  local change
  [[ -n ${TMUX:-""} ]] && change="switch-client" || change="attach-session"
  tmux $change -t "$1"
}

createSessionIfNeeded() {
  local name=$1
  local dir=${2:-$(pwd)}
  tmux list-sessions -F "#{session_name}" \
    | grep -q -E "^${name}$" \
    || tmux new-session -d -c "${dir}" -s "${name}"
}

selectRepo() {
  echo "$(ghq root)/$(ghq list | fzf)"
}

main() {
  if [ $# -eq 1 ]; then
    createSessionIfNeeded "$1"
    changeSession "$1"
    exit
  fi

  local repo
  local session
  repo="$(selectRepo)"
  session="$(echo "$repo" | awk -F/ '{ print $NF }')"

  createSessionIfNeeded "$session" "$repo"
  changeSession "$session"
}

main "$@"
