{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(rm:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rmdir:*)",
      "Bash(unlink:*)",
      "Bash(shred:*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec rm*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase:*)",
      "Bash(git checkout .)",
      "Bash(git clean -f *)",
      "Bash(git add .)",
      "Bash(git add -A)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(npm publish *)",
      "Bash(yarn publish *)",
      "Bash(pnpm publish *)",
      "Bash(*deploy*)",
      "Bash(mongod:*)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(kill -9 *)",
      "Bash(open *)",
      "Bash(osascript *)",
      "Bash(defaults write *)",
      "Read(.ssh/**)",
      "Edit(.ssh/**)",
      "Write(.ssh/**)",
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Read(secrets/**)",
      "Read(**/secrets/**)",
      "Write(secrets/**)",
      "Write(**/secrets/**)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(**/*.pem)",
      "Read(**/credentials*)",
      "Read(.git-credentials)",
      "Read(.config/gh/**)",
      "Edit(.zshrc)",
      "Write(.zshrc)",
      "Edit(.bashrc)",
      "Write(.bashrc)",
      "mcp__supabase__execute_sql",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(helm install *)",
      "Bash(helm upgrade *)",
      "Bash(docker push *)",
      "Bash(aws * --no-cli-pager)",
      "Bash(gcloud * --quiet)"
    ],
    "ask": [
      "Bash(psql *)",
      "Bash(mysql *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-sensitive-reads.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.githubusercontent.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "packagist.org"
      ]
    },
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.bash_history",
        "~/.zsh_history",
        "~/.config/gcloud"
      ]
    }
  },
  "theme": "auto"
}
