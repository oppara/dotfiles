{
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(rm:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rmdir:*)",
      "Bash(unlink:*)",
      "Bash(shred:*)",
      "Bash(find:* -delete*)",
      "Bash(rsync:* --delete*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Read(.ssh/**)",
      "Edit(.ssh/**)",
      "Write(.ssh/**)",
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Read(secrets/**)",
      "Read(**/secrets/**)",
      "Write(secrets/**)",
      "Write(**/secrets/**)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Read(.git-credentials)",
      "Read(.config/gh/**)",
      "Edit(.zshrc)",
      "Write(.zshrc)",
      "Edit(.bashrc)",
      "Write(.bashrc)",
      "mcp__supabase__execute_sql"
    ]
  }
}
